{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} .gemini/hooks/session-start.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "^(check|implement|research)$",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} .gemini/hooks/inject-subagent-context.py",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
